{
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",

    "target": "ES2020",
    "lib": ["ES2020"],

    "module": "esnext",
    "moduleResolution": "bundler",

    "strict": true,

    "types": ["node"],

    "esModuleInterop": true,
    "skipLibCheck": true,

    "forceConsistentCasingInFileNames": true,
    "sourceMap": true
  },
  "include": ["src"]
}